<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<title>Контакты | Центральная избирательная комиссия</title>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css"/>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚖️</text></svg>"/>
<style>
:root{--bg:#0b1120;--bg-alt:#020617;--fg:#e5e7eb;--muted:#9ca3af;--accent:#1d4ed8;--accent-soft:#111827;--border:#1f2937;--card:#020617;--shadow:0 18px 40px rgba(15,23,42,.75)}
[data-theme="light"]{--bg:#f3f4f6;--bg-alt:#fff;--fg:#111827;--accent-soft:#e5e7eb;--border:#d1d5db;--card:#fff;--shadow:0 18px 40px rgba(15,23,42,.15)}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;font-family:system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--fg);line-height:1.6;overflow-x:hidden;padding-bottom:150px;transition:background-color .5s,color .5s,border-color .5s}
a{text-decoration:none;color:inherit}
:focus-visible{outline:2px solid var(--accent);outline-offset:4px}
@keyframes holo{0%{background-position:0%}100%{background-position:200%}}
.holo-text{background:linear-gradient(90deg,#00f260,#0575e6,#f200cb,#00f260);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:holo 3s linear infinite}
.nav-bar{background:var(--bg-alt);position:sticky;top:0;z-index:1000;border-bottom:1px solid var(--border)}
.nav-inner{max-width:1120px;margin:0 auto;padding:.75rem 1rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
.nav-logo{font-weight:800;font-size:1.2rem;color:var(--fg)}
.nav-links{display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap}
.nav-link{padding:.5rem 1rem;border-radius:8px;transition:.3s;color:var(--muted)}
.nav-link:hover{color:var(--fg);background:var(--accent-soft)}
.nav-link.active{color:var(--accent);background:var(--accent-soft)}
.lang-globe{position:relative}
.globe-btn{background:var(--card);border:2px solid var(--border);border-radius:50%;width:44px;height:44px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.3rem;transition:.3s}
.globe-btn:hover{border-color:var(--accent);transform:scale(1.1)}
.globe-flags{position:absolute;right:0;top:55px;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:.5rem;display:none;grid-template-columns:repeat(3,1fr);gap:.4rem;min-width:280px;box-shadow:var(--shadow);z-index:1001}
.globe-flags.show{display:grid}
.flag-item{display:flex;align-items:center;gap:8px;padding:.5rem;border-radius:8px;cursor:pointer;transition:.2s;font-size:.8rem;color:var(--fg)}
.flag-item:hover{background:var(--accent-soft);color:var(--accent)}
.fi{width:1.2em;height:1em;background-size:cover;border-radius:2px}
.theme-toggle{background:var(--card);border:2px solid var(--border);border-radius:999px;padding:.4rem .8rem;cursor:pointer;min-width:44px;font-size:1.2rem}
.container{max-width:1120px;margin:0 auto;padding:2rem 1rem}
.content-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:2rem;margin-bottom:2rem}
.content-card h1,.content-card h2{color:var(--fg);border-bottom:2px solid var(--accent);padding-bottom:.5rem;margin-top:0}
.content-card p{color:var(--muted);line-height:1.8}
.contact-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2rem;margin-top:2rem}
.contact-item{background:var(--bg-alt);border:1px solid var(--border);border-radius:12px;padding:1.5rem}
.contact-item h3{color:var(--accent);margin-top:0}
.contact-item a{color:var(--fg);font-weight:bold}
.contact-item a:hover{color:var(--accent)}
.form-group{margin-bottom:1rem}
.form-group label{display:block;margin-bottom:.5rem;color:var(--fg);font-weight:500}
.form-group input,.form-group textarea{width:100%;padding:.75rem;border:1px solid var(--border);border-radius:8px;background:var(--bg-alt);color:var(--fg);font-family:inherit}
.form-group input:focus,.form-group textarea:focus{outline:none;border-color:var(--accent)}
.form-group textarea{min-height:120px;resize:vertical}
.btn-submit{width:100%;padding:1rem;background:var(--accent);color:#fff;border:none;border-radius:999px;font-weight:bold;cursor:pointer;transition:.3s}
.btn-submit:hover{background:#1e40af;transform:scale(1.02)}
.site-footer{border-top:1px solid var(--border);background:var(--bg-alt);padding:2rem 1rem 3rem;margin-top:4rem}
.footer-inner{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem}
.footer-block h3{margin-bottom:1rem;color:var(--fg);border-bottom:2px solid var(--accent);padding-bottom:.5rem}
.footer-block li{margin-bottom:8px;color:var(--muted);list-style:none}
.social-grid{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:.8rem}
.social-btn{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;transition:.3s;color:#fff}
.social-btn:hover{transform:scale(1.1);filter:brightness(1.15)}
.social-icon{width:20px;height:20px;fill:currentColor}
.social-yt{background:#FF0000}.social-tg{background:#229ED9}.social-fb{background:#1877F2}.social-x{background:#000;border:1px solid #333}.social-ig{background:linear-gradient(45deg,#f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%)}
.social-tt{background:#000;border:1px solid #333}
</style>
</head>
<body>
<nav class="nav-bar">
  <div class="nav-inner">
    <a href="../index.html" class="nav-logo holo-text">ЦИК</a>
    <div class="nav-links">
      <a href="../index.html" class="nav-link" data-i18n="nav_home">Главная</a>
      <a href="about.html" class="nav-link" data-i18n="nav_about">О нас</a>
      <a href="elections.html" class="nav-link" data-i18n="nav_elections">Выборы</a>
      <a href="help.html" class="nav-link" data-i18n="nav_help">Помощь</a>
      <a href="chudo.html" class="nav-link" data-i18n="nav_chudo">CHUDO</a>
      <a href="contact.html" class="nav-link active" data-i18n="nav_contact">Контакты</a>
      
      <div class="lang-globe">
        <button class="globe-btn" id="globeBtn" type="button">🌐</button>
        <div class="globe-flags" id="globeFlags">
          <a href="#" class="flag-item" data-lang="ru"><span class="fi fi-ru"></span> Русский</a>
          <a href="#" class="flag-item" data-lang="be"><span style="display:inline-block;width:1.2em;height:0.8em;background:linear-gradient(to bottom,white 33%,red 33%,red 66%,white 66%);border-radius:2px;"></span> Беларуская</a>
          <a href="#" class="flag-item" data-lang="en"><span class="fi fi-gb"></span> English</a>
        </div>
      </div>
      <button class="theme-toggle" id="themeToggle" type="button"><span id="themeIcon">☀️</span></button>
    </div>
  </div>
</nav>

<main class="container">
  <div class="content-card">
    <h1 class="holo-text" data-i18n="contact_title">Связаться с нами</h1>
    <p data-i18n="contact_text">Мы всегда открыты для сотрудничества, вопросов и предложений. Выберите удобный способ связи.</p>
    
    <div class="contact-grid">
      <div class="contact-item">
        <h3 data-i18n="contact_email_title">Email</h3>
        <p><a href="mailto:yury@chudzinovich.de">yury@chudzinovich.de</a></p>
        <p data-i18n="contact_email_text">Для общих вопросов и предложений</p>
      </div>
      <div class="contact-item">
        <h3 data-i18n="contact_phone_title">Телефон</h3>
        <p><a href="tel:+48795972990">+48 795 972 990</a></p>
        <p data-i18n="contact_phone_text">Пн-Пт, 10:00-18:00 (Варшава)</p>
      </div>
      <div class="contact-item">
        <h3 data-i18n="contact_address_title">Адрес</h3>
        <p>ul. Lokcowa 12</p>
        <p>04-186 Warszawa, Polska</p>
      </div>
      <div class="contact-item">
        <h3 data-i18n="contact_telegram_title">Telegram</h3>
        <p><a href="https://t.me/+48795972990" target="_blank">@cik_belarus</a></p>
        <p data-i18n="contact_telegram_text">Быстрые ответы</p>
      </div>
    </div>
  </div>
  
  <div class="content-card">
    <h2 data-i18n="contact_form_title">Форма обратной связи</h2>
    <form id="contactForm">
      <div class="form-group">
        <label for="name" data-i18n="form_name">Ваше имя</label>
        <input type="text" id="name" name="name" required>
      </div>
      <div class="form-group">
        <label for="email" data-i18n="form_email">Email</label>
        <input type="email" id="email" name="email" required>
      </div>
      <div class="form-group">
        <label for="subject" data-i18n="form_subject">Тема</label>
        <input type="text" id="subject" name="subject" required>
      </div>
      <div class="form-group">
        <label for="message" data-i18n="form_message">Сообщение</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <button type="submit" class="btn-submit" data-i18n="form_send">Отправить</button>
    </form>
  </div>
</main>

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-block">
      <h3 class="holo-text">ЦИК</h3>
      <ul>
        <li>Адрес: Польша, Варшава, ul. Lokcowa 12</li>
        <li>Email: <a href="mailto:yury@chudzinovich.de">yury@chudzinovich.de</a></li>
        <li>Телефон: <a href="tel:+48795972990">+48795972990</a></li>
      </ul>
    </div>
    <div class="footer-block">
      <h3 class="holo-text">Соцсети</h3>
      <div class="social-grid">
        <a href="https://www.youtube.com/channel/UCTXAwovvaec4w9ztbggWMEQ" target="_blank" class="social-btn social-yt"><svg class="social-icon" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
        <a href="https://t.me/+48795972990" target="_blank" class="social-btn social-tg"><svg class="social-icon" viewBox="0 0 24 24"><path d="M11.944 0C5.347 0 0 5.347 0 11.944c0 6.597 5.347 11.944 11.944 11.944 6.597 0 11.944-5.347 11.944-11.944C23.888 5.347 18.541 0 11.944 0zm5.204 8.12l-1.764 8.312c-.133.593-.483.738-.982.458l-2.686-1.98-1.296 1.246c-.144.144-.264.264-.54.264l.192-2.73 4.968-4.488c.216-.192-.048-.3-.336-.108L8.568 12.44 5.916 11.61c-.576-.18-.588-.576.12-.852l10.38-4.008c.48-.18.9.108.732.372z"/></svg></a>
        <a href="https://www.facebook.com/share/1bJi1GCA85/" target="_blank" class="social-btn social-fb"><svg class="social-icon" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
        <a href="https://x.com/CHUDZINOVICH1" target="_blank" class="social-btn social-x"><svg class="social-icon" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
        <a href="https://www.instagram.com/chudzinovichyury" target="_blank" class="social-btn social-ig"><svg class="social-icon" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
        <a href="https://tiktok.com/@chudzinovich" target="_blank" class="social-btn social-tt"><svg class="social-icon" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg></a>
      </div>
    </div>
  </div>
  <p style="text-align:center;margin-top:2rem;color:var(--muted);font-size:.8rem">© 2025 Центральная избирательная комиссия</p>
</footer>

<script>
const translations = {
  ru: {
    nav_home: "Главная", nav_about: "О нас", nav_elections: "Выборы", nav_help: "Помощь", nav_chudo: "CHUDO", nav_contact: "Контакты",
    contact_title: "Связаться с нами",
    contact_text: "Мы всегда открыты для сотрудничества, вопросов и предложений. Выберите удобный способ связи.",
    contact_email_title: "Email",
    contact_email_text: "Для общих вопросов и предложений",
    contact_phone_title: "Телефон",
    contact_phone_text: "Пн-Пт, 10:00-18:00 (Варшава)",
    contact_address_title: "Адрес",
    contact_telegram_title: "Telegram",
    contact_telegram_text: "Быстрые ответы",
    contact_form_title: "Форма обратной связи",
    form_name: "Ваше имя",
    form_email: "Email",
    form_subject: "Тема",
    form_message: "Сообщение",
    form_send: "Отправить"
  },
  be: {
    nav_home: "Галоўная", nav_about: "Пра нас", nav_elections: "Выбары", nav_help: "Дапамога", nav_chudo: "CHUDO", nav_contact: "Кантакты",
    contact_title: "Звязацца з намі",
    contact_text: "Мы заўсёды адкрыты для супрацоўніцтва, пытанняў і прапаноў. Выберыце зручны спосаб сувязі.",
    contact_email_title: "Email",
    contact_email_text: "Для агульных пытанняў і прапаноў",
    contact_phone_title: "Тэлефон",
    contact_phone_text: "Пн-Пт, 10:00-18:00 (Варшава)",
    contact_address_title: "Адрас",
    contact_telegram_title: "Telegram",
    contact_telegram_text: "Хуткія адказы",
    contact_form_title: "Форма зваротнай сувязі",
    form_name: "Ваша імя",
    form_email: "Email",
    form_subject: "Тэма",
    form_message: "Паведамленне",
    form_send: "Адправіць"
  },
  en: {
    nav_home: "Home", nav_about: "About", nav_elections: "Elections", nav_help: "Help", nav_chudo: "CHUDO", nav_contact: "Contact",
    contact_title: "Contact Us",
    contact_text: "We are always open for cooperation, questions and suggestions. Choose a convenient way to contact us.",
    contact_email_title: "Email",
    contact_email_text: "For general questions and suggestions",
    contact_phone_title: "Phone",
    contact_phone_text: "Mon-Fri, 10:00-18:00 (Warsaw)",
    contact_address_title: "Address",
    contact_telegram_title: "Telegram",
    contact_telegram_text: "Quick replies",
    contact_form_title: "Contact Form",
    form_name: "Your Name",
    form_email: "Email",
    form_subject: "Subject",
    form_message: "Message",
    form_send: "Send"
  }
};

function applyLang(lang) {
  if (!translations[lang]) lang = 'ru';
  document.documentElement.lang = lang;
  const t = translations[lang];
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (t[key]) el.textContent = t[key];
  });
  localStorage.setItem('lang', lang);
}

document.addEventListener('DOMContentLoaded', function() {
  const savedLang = localStorage.getItem('lang') || 'ru';
  applyLang(savedLang);
  
  document.getElementById('globeBtn').addEventListener('click', function(e) {
    e.stopPropagation();
    document.getElementById('globeFlags').classList.toggle('show');
  });
  
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.lang-globe')) document.getElementById('globeFlags').classList.remove('show');
  });
  
  document.querySelectorAll('.flag-item').forEach(function(item) {
    item.addEventListener('click', function(e) {
      e.preventDefault();
      applyLang(item.getAttribute('data-lang'));
      document.getElementById('globeFlags').classList.remove('show');
    });
  });
  
  document.getElementById('themeToggle').addEventListener('click', function() {
    const html = document.documentElement;
    const newTheme = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', newTheme);
    document.getElementById('themeIcon').textContent = newTheme === 'dark' ? '☀️' : '🌙';
    localStorage.setItem('theme', newTheme);
  });
  
  const savedTheme = localStorage.getItem('theme');
  if (savedTheme) {
    document.documentElement.setAttribute('data-theme', savedTheme);
    document.getElementById('themeIcon').textContent = savedTheme === 'dark' ? '☀️' : '🌙';
  }
  
  document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    alert('Форма отправлена! Мы свяжемся с вами.');
    this.reset();
  });
});
</script>
</body>
</html>
